# Copy this file to .env for local use.
# Do not commit real values.

AAP_HOST=https://aap.example.com
AAP_TOKEN=change-me
AAP_VERIFY_SSL=true

# Optional one-time token generation inputs. Do not keep real passwords here.
# AAP_USERNAME=admin
# AAP_PASSWORD=change-me

AUTOMATION_HUB_HOST=https://hub.example.com
AUTOMATION_HUB_TOKEN=change-me

REGISTRY_HOST=registry.example.com
REGISTRY_USERNAME=change-me
REGISTRY_PASSWORD=change-me

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/example
JIRA_BASE_URL=https://jira.example.com
JIRA_API_TOKEN=change-me
