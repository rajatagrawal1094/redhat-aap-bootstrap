---
extends: default

rules:
  braces:
    max-spaces-inside: 1
  comments-indentation: false
  line-length:
    max: 140
    level: warning
  comments:
    min-spaces-from-content: 1
  truthy:
    allowed-values: ["true", "false"]
  document-start:
    present: true
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true

ignore: |
  .cache/
  .github/
  build/
  dist/
